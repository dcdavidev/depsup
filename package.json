{
  "name": "@deps-up/source",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "fmt": "pnpm dlx prettier . --write",
    "lint": "pnpm dlx eslint --fix .",
    "lint:fmt": "pnpm run lint && pnpm run fmt"
  },
  "config": {
    "commitizen": {
      "path": "git-cz",
      "czConfig": "./commitlint.config.mjs"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@cspell/cspell-types": "^9.3.0",
    "@nx/js": "22.0.3",
    "@prettier/plugin-xml": "^3.4.2",
    "@spellbookx/commitlint-config": "^0.22.16",
    "@spellbookx/cspell-config": "^0.22.14",
    "@spellbookx/eslint-plugin": "^0.27.6",
    "@spellbookx/prettier-config": "^0.24.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.1",
    "@swc/helpers": "~0.5.17",
    "commitizen": "^4.3.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "cspell": "^9.3.0",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.1",
    "nx": "22.0.3",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-ini": "^1.3.0",
    "prettier-plugin-packagejson": "^2.5.19",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-properties": "^0.3.0",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "prettier-plugin-toml": "^2.0.6",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22.20.0",
      "onFail": "download"
    }
  }
}
